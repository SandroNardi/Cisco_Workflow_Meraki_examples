      {
        "unique_name": "definition_activity_02VJRTCIJ6AAK08yx0L0RVK06eaWfyNjlZq",
        "name": "Execute Python Script",
        "title": "Execute Python Script",
        "type": "python3.script",
        "base_type": "activity",
        "properties": {
          "action_timeout": 180,
          "continue_on_failure": false,
          "description": "Execute Python Script",
          "display_name": "Execute Python Script",
          "script": "import sys\nimport json\n\ndef build_approval_request(username: str, network_name: str, appliance: dict, access_points: list) -> str:\n\n    # --- Appliance ---\n    appliance_model  = appliance.get(\"model\",  \"N/A\")\n    appliance_serial = appliance.get(\"serial\", \"N/A\")\n\n    # --- Access Point lines ---\n    ap_lines = \"\"\n    for idx, device in enumerate(access_points, start=1):\n        model  = device.get(\"model\",  \"N/A\")\n        serial = device.get(\"serial\", \"N/A\")\n        ap_lines += f\"  {idx}. {model} - {serial}\\n\"\n\n    if not ap_lines:\n        ap_lines = \"  No access points selected.\\n\"\n\n    total_devices = 1 + len(access_points)\n\n    approval_text = (\n        \"NETWORK CREATION - APPROVAL REQUEST\\n\"\n        \"=====================================\\n\\n\"\n        f\"Requested by : {username}\\n\"\n        f\"Network name : {network_name}\\n\\n\"\n        \"-------------------------------------\\n\"\n        \"DEVICES REQUESTED FOR ENROLLMENT\\n\"\n        \"-------------------------------------\\n\\n\"\n        \"Appliance (1 device):\\n\"\n        f\"  Model  : {appliance_model}\\n\"\n        f\"  Serial : {appliance_serial}\\n\\n\"\n        f\"Access Points ({len(access_points)} device(s)):\\n\"\n        f\"{ap_lines}\\n\"\n        \"-------------------------------------\\n\"\n        \"SUMMARY\\n\"\n        \"-------------------------------------\\n\"\n        \"  Appliances   : 1\\n\"\n        f\"  Access Points: {len(access_points)}\\n\"\n        f\"  Total Devices: {total_devices}\\n\\n\"\n        \"-------------------------------------\\n\"\n        \"APPROVER ACTION REQUIRED\\n\"\n        \"-------------------------------------\\n\"\n        f\"User '{username}' has requested the creation of a new network\\n\"\n        f\"named '{network_name}' with {total_devices} device(s) listed above.\\n\"\n        \"Please review and approve or reject this request.\\n\\n\"\n        \"Note: This message was automatically generated.\\n\"\n    )\n\n    return approval_text\n\n\ndef collect_serials(appliance: dict, access_points: list) -> list:\n    \"\"\"\n    Returns a flat array of all serial numbers involved in the operation.\n    \"\"\"\n    serials = []\n\n    # --- Appliance serial ---\n    appliance_serial = appliance.get(\"serial\")\n    if appliance_serial:\n        serials.append(appliance_serial)\n\n    # --- Access Point serials ---\n    for device in access_points:\n        serial = device.get(\"serial\")\n        if serial:\n            serials.append(serial)\n\n    return serials\n\n\n# ---------------------------------------------------------------------------\n# Entry point\n# ---------------------------------------------------------------------------\narg_username     = sys.argv[1]                  # string\narg_network_name = sys.argv[2]                  # string\narg_appliance    = json.loads(sys.argv[3])       # single dict\narg_access_point = json.loads(sys.argv[4])       # list of dicts\n\n# ---------------------------------------------------------------------------\n# Build and store result - not printed\n# ---------------------------------------------------------------------------\napproval_message = build_approval_request(\n    username      = arg_username,\n    network_name  = arg_network_name,\n    appliance     = arg_appliance,\n    access_points = arg_access_point\n)\n\n# ---------------------------------------------------------------------------\n# Collect all serial numbers into a flat array - not printed\n# ---------------------------------------------------------------------------\nselected_serials = collect_serials(\n    appliance     = arg_appliance,\n    access_points = arg_access_point\n)",
          "script_arguments": [
            "$workflow.definition_workflow_02VGBGTZVF9N31eR2YsLS9jfv7CpAOweV2a.output.started_by$",
            "$activity.definition_activity_02VJR1DIP93Y673jSSgthCbf63cx0BmInnI.output.prompt_response.Network name$",
            "$activity.definition_activity_02VJR1DIP93Y673jSSgthCbf63cx0BmInnI.output.prompt_response.Security appliance (MX)$",
            "$activity.definition_activity_02VJR1DIP93Y673jSSgthCbf63cx0BmInnI.output.prompt_response.Access point (MR)$"
          ],
          "script_queries": [
            {
              "script_query": "approval_message",
              "script_query_name": "approval_message",
              "script_query_type": "string"
            },
            {
              "script_query": "selected_serials",
              "script_query_name": "selected_serials",
              "script_query_type": "array"
            }
          ],
          "skip_execution": false
        },
        "object_type": "definition_activity"
      },
