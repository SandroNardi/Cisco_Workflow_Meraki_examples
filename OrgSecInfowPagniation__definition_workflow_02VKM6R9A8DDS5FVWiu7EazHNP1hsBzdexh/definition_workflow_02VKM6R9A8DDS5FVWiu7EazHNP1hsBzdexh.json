                          },
                          {
                            "unique_name": "definition_activity_02VKM6SAH5AJ91i1YI5UAXlXCOZ9x4BL0pE",
                            "name": "Process and Accumulate SSIDs",
                            "title": "Process and Accumulate SSIDs",
                            "type": "python3.script",
                            "base_type": "activity",
                            "properties": {
                              "action_timeout": 180,
                              "continue_on_failure": false,
                              "display_name": "Process and Accumulate SSIDs",
                              "script": "import sys\nimport json\n\ncurr_table = json.loads(sys.argv[1]) if sys.argv[1] else []\norg_id = sys.argv[2]\norg_name = sys.argv[3]\n\n# Organization API status\ntry:\n    api_status_res = json.loads(sys.argv[4]) if sys.argv[4] else {}\nexcept:\n    api_status_res = {}\n\nif not isinstance(api_status_res, dict):\n    api_status_res = {}\n\n# Organization SAML\ntry:\n    saml_res = json.loads(sys.argv[5]) if sys.argv[5] else {}\nexcept:\n    saml_res = {}\n\nif not isinstance(saml_res, dict):\n    saml_res = {}\n\n# Organization Login Security\ntry:\n    login_sec_res = json.loads(sys.argv[6]) if sys.argv[6] else {}\nexcept:\n    login_sec_res = {}\n\nif not isinstance(login_sec_res, dict):\n    login_sec_res = {}\n\nentry = {\n    'orgId': org_id,\n    'orgName': org_name,\n    'apiEnabled': api_status_res.get('enabled'),\n    'samlEnabled': saml_res.get('enabled'),\n    'enforcePasswordExpiration': login_sec_res.get('enforcePasswordExpiration'),\n    'passwordExpirationDays': login_sec_res.get('passwordExpirationDays'),\n    'enforceDifferentPasswords': login_sec_res.get('enforceDifferentPasswords'),\n    'numDifferentPasswords': login_sec_res.get('numDifferentPasswords'),\n    'enforceStrongPasswords': login_sec_res.get('enforceStrongPasswords'),\n    'minimumPasswordLength': login_sec_res.get('minimumPasswordLength'),\n    'enforceAccountLockout': login_sec_res.get('enforceAccountLockout'),\n    'accountLockoutAttempts': login_sec_res.get('accountLockoutAttempts'),\n    'enforceIdleTimeout': login_sec_res.get('enforceIdleTimeout'),\n    'idleTimeoutMinutes': login_sec_res.get('idleTimeoutMinutes'),\n    'enforceTwoFactorAuth': login_sec_res.get('enforceTwoFactorAuth'),\n    'enforceLoginIpRanges': login_sec_res.get('enforceLoginIpRanges'),\n    'loginIpRanges': login_sec_res.get('loginIpRanges'),\n    'apiAuthentication': login_sec_res.get('apiAuthentication')\n}\n\n# Remove keys that are not present (None) so each org only includes configured fields\nentry = {k: v for k, v in entry.items() if v is not None or k in ('orgId', 'orgName')}\n\ncurr_table.append(entry)\n\nresult = json.dumps(curr_table)",
                              "script_arguments": [
                                "$workflow.definition_workflow_02VKM6R9A8DDS5FVWiu7EazHNP1hsBzdexh.local.variable_workflow_02VKNLQ2N5VVS6VXiW3keCMsD600wMoSVP3$",
