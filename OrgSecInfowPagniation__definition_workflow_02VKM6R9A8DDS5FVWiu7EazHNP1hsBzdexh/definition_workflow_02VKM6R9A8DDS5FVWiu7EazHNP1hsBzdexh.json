                                "$activity.definition_activity_02VKM6RXW7IKU1AkZOqlKrzGVGpUS4n1FlR.input.source_array[@].api$",
                                "$activity.definition_activity_02VKNOWC0FBCZ4NZUVyiQTPJnwK44Z34Jhi.output.variable_workflow_02OARCLNJFPHK5jZsgMQbFlodjutPmTBWmo$",
                                "$activity.definition_activity_02VKNSR72I5EF3Cl3k9s5W9W3zY6VnnlrJw.output.variable_workflow_02OARCLK8FI080VOdgA6U4nG7BI1OmuFvN6$"
                              ],
