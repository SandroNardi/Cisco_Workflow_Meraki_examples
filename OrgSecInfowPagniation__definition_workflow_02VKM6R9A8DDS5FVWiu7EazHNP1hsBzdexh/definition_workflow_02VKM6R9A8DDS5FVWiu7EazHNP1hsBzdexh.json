          "script": "import json\n\n# Parse the input JSON string\ndata = json.loads(arg1)\n\nif data:\n    # Extract headers from the keys of the first dictionary\n    # We exclude nested dictionaries like 'apiAuthentication' for a clean table\n    headers = [key for key in data[0].keys() if isinstance(data[0][key], (str, int, bool, float))]\n    \n    # Start building the HTML table\n    html = '<table border=\"1\" style=\"border-collapse: collapse; width: 100%;\">'\n    \n    # Add header row\n    html += '<thead><tr>'\n    for header in headers:\n        html += f'<th style=\"padding: 8px; background-color: #f2f2f2;\">{header}</th>'\n    html += '</tr></thead>'\n    \n    # Add data rows\n    html += '<tbody>'\n    for entry in data:\n        html += '<tr>'\n        for header in headers:\n            value = entry.get(header, \"\")\n            html += f'<td style=\"padding: 8px;\">{value}</td>'\n        html += '</tr>'\n    html += '</tbody></table>'\n    \n    # Assign the final string to the result variable\n    result = html\nelse:\n    result = \"<p>No data available.</p>\"",
