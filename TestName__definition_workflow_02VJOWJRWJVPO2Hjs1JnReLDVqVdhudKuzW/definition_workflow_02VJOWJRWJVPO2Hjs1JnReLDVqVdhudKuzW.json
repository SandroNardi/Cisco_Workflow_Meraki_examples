                            "unique_name": "definition_activity_02VJOWJRWOHTC7GMSmsiwU8MSRVlZHEziqO",
                            "name": "Process and Accumulate SSIDs",
                            "title": "Process and Accumulate SSIDs",
                            "type": "python3.script",
                            "base_type": "activity",
                            "properties": {
                              "action_timeout": 180,
                              "continue_on_failure": false,
                              "display_name": "Process and Accumulate SSIDs",
                              "script": "import sys\nimport json\n\ncurr_table = json.loads(sys.argv[1]) if sys.argv[1] else []\nnet_id = sys.argv[2]\n\n# Wireless SSIDs\ntry:\n    wireless_res = json.loads(sys.argv[3]) if sys.argv[3] else []\nexcept:\n    wireless_res = []\n\n\nif not isinstance(wireless_res, list):\n    wireless_res = []\n\nfor ssid in wireless_res:\n    if ssid.get('enabled') is True:\n        curr_table.append({\n            'networkId': net_id,\n            'ssidName': ssid.get('name'),\n            'authMode': ssid.get('authMode')\n        })\n\nresult = json.dumps(curr_table)\n",
                              "script_arguments": [
                                "$workflow.definition_workflow_02VJOWJRWJVPO2Hjs1JnReLDVqVdhudKuzW.local.variable_workflow_02VJOWJRWLK2O2xCxkxzmQqskLfzZhp7vWr$",
